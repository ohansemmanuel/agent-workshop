# Copy this file to .env.local and fill in your key.
#   cp .env.example .env.local

# Required: your OpenAI API key.
OPENAI_API_KEY=sk-your-key-here

# Optional: which model to use. Defaults to gpt-5-mini if unset.
# Set this to any chat/responses model your account can access.
OPENAI_MODEL=gpt-5-mini

# "Break the agent" demo dial. Leave unset for the model's normal reasoning, which
# makes the agent robust (and shows rich "thinking"). Set to "minimal" (or "low")
# to remove the safety net so it drifts under load — wrong Refs line, wrong SLA
# tiers, sloppy format. Restart the dev server after changing.
# OPENAI_REASONING_EFFORT=minimal
