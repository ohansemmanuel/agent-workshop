# Copy this file to .env.local and fill in your key.
#   cp .env.example .env.local

# Required: your OpenAI API key.
OPENAI_API_KEY=sk-your-key-here

# Optional: which model to use. Defaults to gpt-5-mini if unset.
# Set this to any chat/responses model your account can access. (bash-tool is
# model-agnostic — the same skills work behind any AI SDK model.)
OPENAI_MODEL=gpt-5-mini

# "Reasoning effort" dial, same knob as issue-triage-2x. Leave unset for the model's
# normal reasoning. Set to "minimal" (or "low") to strip the safety net. The A/B point:
# 2x drifts on "minimal" because it must reason over ~14k of bloat; this app keeps the
# prompt thin and loads only the runbook it needs, so it should still hold R1–R5 even
# on "minimal" — the fix is less context, not more reasoning. Restart the dev server
# after changing.
# OPENAI_REASONING_EFFORT=minimal
