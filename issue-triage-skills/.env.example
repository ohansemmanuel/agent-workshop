# Copy this file to .env.local and fill in your key.
#   cp .env.example .env.local

# Required: your OpenAI API key.
OPENAI_API_KEY=sk-your-key-here

# Optional: which model to use. Defaults to gpt-5-mini if unset.
# Set this to any chat/responses model your account can access. (bash-tool is
# model-agnostic — the same skills work behind any AI SDK model.)
OPENAI_MODEL=gpt-5-mini

# Note: there's no "break the agent" dial here. issue-triage-2x had one
# (OPENAI_REASONING_EFFORT) to force drift under a bloated prompt. This app keeps
# the prompt thin and loads runbooks on demand, so the agent stays robust by
# design — that's the whole point of the "after".
